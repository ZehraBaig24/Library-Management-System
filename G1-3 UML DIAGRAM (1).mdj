							"left": 3312,
							"top": 3736,
							"width": 208,
							"height": 96,
							"text": "run() is the main entry point / application loop for the system.\n\n"
						},
						{
							"_type": "UMLNoteView",
							"_id": "AAAAAAGdJ8XMBXASec4=",
							"_parent": {
								"$ref": "AAAAAAFF+qBtyKM79qY="
							},
							"lineColor": "#840084",
							"fillColor": "#FFD8FF",
							"font": "Arial;13;0",
							"parentStyle": false,
							"left": 2248,
							"top": 672,
							"width": 232,
							"height": 96,
							"text": "+resourceID: string\nThis attribute represents ID in this format:\nPR-xx -> For Physical Resources\nOR-xx -> For Online Resources"
						},
						{
							"_type": "UMLTextBoxView",
							"_id": "AAAAAAGdJ8iVzNTqMyY=",
							"_parent": {
								"$ref": "AAAAAAFF+qBtyKM79qY="
							},
							"lineColor": "#FFFFFF",
							"fillColor": "#6DCEFF",
							"fontColor": "#FFFFFF",
							"font": "Arial;42;0",
							"parentStyle": false,
							"left": 200,
							"top": 1992,
							"width": 280,
							"height": 608,
							"text": "                                                MAIN \nBUSINESS CLASSES\n(SERVICE LAYER)\n\n\n"
						},
						{
							"_type": "UMLNoteView",
							"_id": "AAAAAAGdJ99ZWMZEkzI=",
							"_parent": {
								"$ref": "AAAAAAFF+qBtyKM79qY="
							},
							"lineColor": "#00B799",
							"fillColor": "#D8FFF8",
							"font": "Arial;13;0",
							"parentStyle": false,
							"left": 2792,
							"top": 3280,
							"width": 432,
							"height": 232,
							"text": "Keypoints:\n1) borrow only if resource is available\n2) max 2 borrows per member per day\n\n4) reference resources are non-borrowable\n5) physical: late fine + damage charge\n6) online: no late fine, direct access charge + revocation policy\n7) IDCount_ variable supports system-generated IDs so kept as static\n8) const keyword implementation shown in UML through isQuery property\n\n\n\n\n( For implementation of Rule no. 5 and 6, method:\n+applyReturnPolicy(in member:Member, record:BorrowRecord): void\nis kept pure virtual in the abstract LibraryResource class\n"
						},
